  </main>
  <footer style="margin-top: auto; padding: 1.75rem 2rem; border-top: 1px solid var(--rule); text-align: center; font-size: 0.75rem; color: var(--ink-faint); background: var(--surface);">
    <p style="margin: 0; max-width: none; color: var(--ink-faint); letter-spacing: 0.02em;">
      Sistema de Debida Diligencia Simplificada (DDS) &middot; Cumplimiento Regulatorio SSNF &middot; Ley 23 de 2015
    </p>
  </footer>

  <script>
    const token = sessionStorage.getItem('token');
    const rol = sessionStorage.getItem('rol');
    const isLoginPage = window.location.pathname === '/login';

    if (!token && !isLoginPage) {
      window.location.href = '/login';
    }

    if (token) {
      const mainNav = document.getElementById('main-nav');
      if (mainNav) mainNav.style.display = 'block';

      const roleBadge = document.getElementById('user-role-badge');
      if (roleBadge) roleBadge.textContent = rol;

      const currentPath = window.location.pathname;
      const navList = document.getElementById('nav-list');
      if (navList && (currentPath === '/formularios' || currentPath === '/')) {
        navList.classList.add('active');
      }
    }

    const logoutBtn = document.getElementById('logout-button');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => {
        sessionStorage.removeItem('token');
        sessionStorage.removeItem('rol');
        window.location.href = '/login';
      });
    }

    // Alertas sin iconos: etiqueta tipográfica en monospace + borde lateral
    function showAlert(mensaje, tipo = 'success') {
      const container = document.getElementById('alert-container');
      if (!container) return;

      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${tipo}`;
      alertDiv.role = 'alert';

      const labels = {
        success: 'Completado',
        warning: 'Atencion',
        error: 'Error',
        info: 'Informacion'
      };

      const label = document.createElement('span');
      label.className = 'alert-label';
      label.textContent = labels[tipo] || labels.info;

      const msg = document.createElement('span');
      msg.className = 'alert-msg';
      msg.textContent = mensaje;

      alertDiv.appendChild(label);
      alertDiv.appendChild(msg);
      container.appendChild(alertDiv);

      alertDiv.style.opacity = '0';
      alertDiv.style.transform = 'translateY(-4px)';
      alertDiv.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
      requestAnimationFrame(() => {
        alertDiv.style.opacity = '1';
        alertDiv.style.transform = 'translateY(0)';
      });

      setTimeout(() => {
        alertDiv.style.opacity = '0';
        alertDiv.style.transform = 'translateY(-4px)';
        setTimeout(() => alertDiv.remove(), 300);
      }, 5000);
    }

    async function apiFetch(url, options = {}) {
      const token = sessionStorage.getItem('token');
      const headers = {
        'Content-Type': 'application/json',
        ...(token ? { 'Authorization': `Bearer ${token}` } : {}),
        ...(options.headers || {})
      };

      try {
        const response = await fetch(url, { ...options, headers });
        if (response.status === 401) {
          sessionStorage.removeItem('token');
          sessionStorage.removeItem('rol');
          window.location.href = '/login';
          throw new Error('Sesion expirada');
        }
        return response;
      } catch (err) {
        console.error('Error de red API:', err);
        throw err;
      }
    }
  </script>
</body>
</html>
