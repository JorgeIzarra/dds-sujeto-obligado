<%- include('layout_header') %>

<div class="glass-card" style="max-width: 900px; margin: 2rem auto;">
  <!-- Progress Wizard -->
  <div class="wizard-steps" id="wizard-container">
    <a href="/formularios/<%= id %>/identificacion" class="wizard-step completed">
      <span class="step-number">1</span> Identificación
    </a>
    <a href="/formularios/<%= id %>/contacto" class="wizard-step completed">
      <span class="step-number">2</span> Contacto
    </a>
    <a href="/formularios/<%= id %>/perfil" class="wizard-step completed">
      <span class="step-number">3</span> Perfil
    </a>
    <a href="/formularios/<%= id %>/documentos" class="wizard-step completed">
      <span class="step-number">4</span> Documentos
    </a>
    <a href="/formularios/<%= id %>/resumen" class="wizard-step active">
      <span class="step-number">5</span> Resumen
    </a>
  </div>

  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h2>Resumen e Indicadores del Formulario</h2>
    <div id="folio-badge-container"></div>
  </div>

  <div id="resumen-content" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Identificacion del Cliente -->
    <div style="background: var(--surface-alt); padding: 1.5rem; border-radius: 2px; border: 1px solid var(--rule); border-top: 3px solid var(--accent);">
      <h3 style="font-size: 0.72rem; margin-bottom: 1rem; font-family: var(--font-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent);">01 · Identificacion</h3>
      <table style="width: 100%; border-collapse: collapse; font-size: 0.88rem;">
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; width: 40%; color: var(--ink);">Nombre</td><td id="res-nombre" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Tipo cliente</td><td id="res-tipoCliente" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Documento</td><td id="res-doc" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Nacionalidad</td><td id="res-nacionalidad" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Nacimiento</td><td id="res-fechaNac" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Persona PEP</td><td id="res-pep" style="padding: 0.55rem 0;">&mdash;</td></tr>
      </table>
    </div>

    <!-- Datos de Contacto -->
    <div style="background: var(--surface-alt); padding: 1.5rem; border-radius: 2px; border: 1px solid var(--rule); border-top: 3px solid var(--accent);">
      <h3 style="font-size: 0.72rem; margin-bottom: 1rem; font-family: var(--font-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent);">02 · Contacto</h3>
      <table style="width: 100%; border-collapse: collapse; font-size: 0.88rem;">
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; width: 30%; color: var(--ink);">Direccion</td><td id="res-direccion" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Telefono</td><td id="res-telefono" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Correo</td><td id="res-correo" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
      </table>
    </div>

    <!-- Perfil Economico -->
    <div style="background: var(--surface-alt); padding: 1.5rem; border-radius: 2px; border: 1px solid var(--rule); border-top: 3px solid var(--accent);">
      <h3 style="font-size: 0.72rem; margin-bottom: 1rem; font-family: var(--font-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent);">03 · Perfil economico</h3>
      <table style="width: 100%; border-collapse: collapse; font-size: 0.88rem;">
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; width: 45%; color: var(--ink);">Actividad</td><td id="res-actividad" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Origen de fondos</td><td id="res-fuente" style="padding: 0.55rem 0; color: var(--ink-muted);">&mdash;</td></tr>
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Ingreso mensual</td><td id="res-ingreso" style="padding: 0.55rem 0; color: var(--ink-muted); font-family: var(--font-mono);">&mdash;</td></tr>
        <tr style="border-bottom: 1px solid var(--rule);"><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Volumen transaccional</td><td id="res-volumen" style="padding: 0.55rem 0; color: var(--ink-muted); font-family: var(--font-mono);">&mdash;</td></tr>
        <tr><td style="padding: 0.55rem 0; font-weight: 600; color: var(--ink);">Clasificacion riesgo</td><td id="res-riesgo" style="padding: 0.55rem 0;">&mdash;</td></tr>
      </table>
    </div>

    <!-- Lista de Documentos -->
    <div style="background: var(--surface-alt); padding: 1.5rem; border-radius: 2px; border: 1px solid var(--rule); border-top: 3px solid var(--accent);">
      <h3 style="font-size: 0.72rem; margin-bottom: 1rem; font-family: var(--font-body); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent);">04 · Documentos</h3>
      <div id="res-docs-list" style="font-size: 0.88rem; max-height: 200px; overflow-y: auto;">
        Cargando documentos...
      </div>
    </div>
  </div>

  <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 2.5rem; border-top: 1px solid var(--rule); padding-top: 1.5rem;">
    <a href="/formularios" class="btn btn-secondary">Volver a bandeja</a>

    <div style="display: flex; gap: 0.75rem;" id="actions-container">
      <a href="/formularios/<%= id %>/documentos" class="btn btn-secondary" id="btn-atras">Paso anterior</a>
      <button id="btn-guardar" class="btn btn-primary">Aprobar y guardar</button>
    </div>
  </div>
</div>

<script>
  const formId = '<%= id %>';
  let estadoFormulario = 'BORRADOR';

  // Cargar todos los datos
  document.addEventListener('DOMContentLoaded', async () => {
    await cargarDatosResumen();
  });

  async function cargarDatosResumen() {
    try {
      const response = await apiFetch(`/api/formularios/${formId}`);
      if (response.status === 200) {
        const data = await response.json();
        
        estadoFormulario = data.estado;

        const folioContainer = document.getElementById('folio-badge-container');
        if (data.folio) {
          folioContainer.innerHTML = `
            <span style="background: var(--success-soft); color: var(--success); border: 1px solid var(--success); padding: 0.5rem 1rem; border-radius: 2px; font-weight: 600; font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 0.06em;">
              FOLIO ${data.folio}
            </span>
          `;
          const wizard = document.getElementById('wizard-container');
          if (wizard) wizard.style.display = 'none';
        } else {
          folioContainer.innerHTML = `
            <span style="background: var(--surface); color: var(--ink-muted); border: 1px solid var(--rule-strong); padding: 0.5rem 1rem; border-radius: 2px; font-weight: 600; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; font-family: var(--font-mono);">
              Borrador
            </span>
          `;
        }

        // 1. Identificación
        if (data.cliente) {
          document.getElementById('res-nombre').textContent = data.cliente.nombre;
          document.getElementById('res-tipoCliente').textContent = data.cliente.tipoCliente;
          document.getElementById('res-doc').textContent = `${data.cliente.tipoDocumento} - ${data.cliente.numDocumento}`;
          document.getElementById('res-nacionalidad').textContent = data.cliente.nacionalidad;
          document.getElementById('res-fechaNac').textContent = data.cliente.fechaNacimiento || '—';
          
          const pepBadge = document.getElementById('res-pep');
          if (data.cliente.esPep) {
            pepBadge.innerHTML = `<span style="background: var(--error-soft); color: var(--error); padding: 0.15rem 0.5rem; border-radius: 2px; font-size: 0.7rem; font-weight: 600; font-family: var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; border: 1px solid var(--error);">Si · PEP</span>`;
          } else {
            pepBadge.innerHTML = `<span style="background: var(--success-soft); color: var(--success); padding: 0.15rem 0.5rem; border-radius: 2px; font-size: 0.7rem; font-weight: 600; font-family: var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; border: 1px solid var(--success);">No</span>`;
          }
        }

        // 2. Contacto
        if (data.datosContacto) {
          document.getElementById('res-direccion').textContent = data.datosContacto.direccion;
          document.getElementById('res-telefono').textContent = data.datosContacto.telefono;
          document.getElementById('res-correo').textContent = data.datosContacto.correo;
        }

        // 3. Perfil Económico
        if (data.perfilEconomico) {
          document.getElementById('res-actividad').textContent = data.perfilEconomico.actividad;
          document.getElementById('res-fuente').textContent = data.perfilEconomico.fuenteIngresos;
          document.getElementById('res-ingreso').textContent = `$${parseFloat(data.perfilEconomico.ingresoMensual).toLocaleString()}`;
          document.getElementById('res-volumen').textContent = `$${parseFloat(data.perfilEconomico.volumenTransacciones).toLocaleString()}`;
        }

        const riesgoCell = document.getElementById('res-riesgo');
        if (data.clasificacionRiesgo) {
          const isBajo = data.clasificacionRiesgo === 'BAJO';
          riesgoCell.innerHTML = isBajo
            ? `<span style="background: var(--success-soft); color: var(--success); padding: 0.25rem 0.6rem; border-radius: 2px; font-weight: 600; font-size: 0.74rem; font-family: var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; border: 1px solid var(--success);">Bajo</span>`
            : `<span style="background: var(--error-soft); color: var(--error); padding: 0.25rem 0.6rem; border-radius: 2px; font-weight: 600; font-size: 0.74rem; font-family: var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase; border: 1px solid var(--error);">Reforzada · No elegible</span>`;
        } else {
          riesgoCell.innerHTML = `<span style="color: var(--ink-faint); font-style: italic; font-size: 0.85rem;">Por clasificar</span>`;
        }

        // 4. Documentos
        const docsList = document.getElementById('res-docs-list');
        docsList.innerHTML = '';
        if (!data.documentos || data.documentos.length === 0) {
          docsList.innerHTML = `<span style="color: var(--text-secondary); font-style: italic;">Sin documentos agregados</span>`;
        } else {
          const ul = document.createElement('ul');
          ul.style.listStyle = 'none';
          ul.style.display = 'flex';
          ul.style.flexDirection = 'column';
          ul.style.gap = '0.5rem';

          data.documentos.forEach(doc => {
            const li = document.createElement('li');
            li.style.background = 'var(--surface)';
            li.style.border = '1px solid var(--rule)';
            li.style.padding = '0.6rem 0.85rem';
            li.style.borderRadius = '2px';
            li.style.display = 'flex';
            li.style.justifyContent = 'space-between';
            li.style.alignItems = 'center';

            const statusColor = doc.verificado ? 'var(--success)' : 'var(--warning)';
            const statusText = doc.verificado ? 'Verificado' : 'Pendiente';

            li.innerHTML = `
              <div>
                <span style="font-weight: 600; color: var(--ink); font-size: 0.88rem;">${doc.tipo}</span>
                <div style="font-size: 0.72rem; color: var(--ink-faint); margin-top: 0.15rem;">${doc.baseLegal || ''}</div>
              </div>
              <span style="font-size: 0.68rem; font-weight: 600; color: ${statusColor}; font-family: var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase;">${statusText}</span>
            `;
            ul.appendChild(li);
          });
          docsList.appendChild(ul);
        }

        // Actualizar Botones de Acciones
        actualizarBotones(data.estado);
      }
    } catch (err) {
      showAlert('Error de conexión al cargar resumen', 'error');
    }
  }

  function actualizarBotones(estado) {
    const container = document.getElementById('actions-container');
    if (estado === 'GUARDADO') {
      container.innerHTML = `
        <button id="btn-pdf" class="btn btn-primary">
          Descargar PDF completo
        </button>
      `;

      document.getElementById('btn-pdf').addEventListener('click', descargarReportePDF);
    } else {
      container.innerHTML = `
        <a href="/formularios/${formId}/documentos" class="btn btn-secondary" id="btn-atras">Paso anterior</a>
        <button id="btn-guardar" class="btn btn-primary">Aprobar y guardar</button>
      `;

      document.getElementById('btn-guardar').addEventListener('click', guardarFormularioDDS);
    }
  }

  async function guardarFormularioDDS() {
    try {
      showAlert('Procesando firma y asignación de Folio...', 'warning');
      const response = await apiFetch(`/api/formularios/${formId}/guardar`, {
        method: 'POST'
      });

      const data = await response.json();

      if (response.status === 200) {
        showAlert('Formulario guardado y aprobado exitosamente', 'success');
        await cargarDatosResumen();
      } else {
        // Mostrar alerta regulativa (ej. PEP, DEF006 o falta de documento verificado)
        showAlert(data.error?.mensaje || 'Error al aprobar el formulario', 'error');
      }
    } catch (err) {
      showAlert('Error al procesar la aprobación del formulario', 'error');
    }
  }

  async function descargarReportePDF() {
    showAlert('Generando PDF en segundo plano...', 'warning');
    const btnPdf = document.getElementById('btn-pdf');
    btnPdf.disabled = true;
    btnPdf.textContent = 'Generando...';

    try {
      const response = await apiFetch(`/api/formularios/${formId}/pdf`);
      const { jobId } = await response.json();

      const pollInterval = setInterval(async () => {
        const pollRes = await apiFetch(`/api/formularios/${formId}/pdf/${jobId}`);

        if (pollRes.status === 200) {
          clearInterval(pollInterval);

          const blob = await pollRes.blob();
          const downloadUrl = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = downloadUrl;
          a.download = `Reporte-DDS-${formId}.pdf`;
          document.body.appendChild(a);
          a.click();
          a.remove();

          showAlert('Reporte PDF descargado con exito', 'success');
          btnPdf.disabled = false;
          btnPdf.textContent = 'Descargar PDF completo';
        } else if (pollRes.status === 500) {
          clearInterval(pollInterval);
          showAlert('Error interno en la generacion del PDF', 'error');
          btnPdf.disabled = false;
          btnPdf.textContent = 'Descargar PDF completo';
        }
      }, 500);
    } catch (err) {
      showAlert('Error al contactar con la exportadora de PDF', 'error');
      btnPdf.disabled = false;
      btnPdf.textContent = 'Descargar PDF completo';
    }
  }
</script>

<%- include('layout_footer') %>
