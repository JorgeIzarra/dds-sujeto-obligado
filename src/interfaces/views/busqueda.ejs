<%- include('layout_header') %>

<div class="glass-card">
  <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2.5rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--rule);">
    <div>
      <span style="font-family: var(--font-mono); font-size: 0.68rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); display: block; margin-bottom: 0.5rem;">Bandeja principal</span>
      <h1 style="margin: 0;">Formularios DDS</h1>
    </div>
    <button id="btn-nuevo" class="btn btn-primary">
      Nuevo formulario
    </button>
  </div>

  <form id="search-form" style="display: grid; grid-template-columns: 1fr 1fr auto; gap: 1rem; margin-bottom: 2rem; background: var(--surface-alt); padding: 1.5rem; border-radius: 2px; border: 1px solid var(--rule); border-left: 3px solid var(--accent);">
    <div class="form-group" style="margin: 0;">
      <label for="search-folio">Filtrar por folio</label>
      <input type="text" id="search-folio" class="input-control" placeholder="DDS-2026-000001">
    </div>
    <div class="form-group" style="margin: 0;">
      <label for="search-nombre">Filtrar por nombre del cliente</label>
      <input type="text" id="search-nombre" class="input-control" placeholder="Ana Lopez">
    </div>
    <div style="display: flex; align-items: flex-end;">
      <button type="submit" class="btn btn-secondary" style="height: 42px; width: 100%;">Buscar</button>
    </div>
  </form>

  <div style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
      <thead>
        <tr style="border-bottom: 2px solid var(--rule-strong); color: var(--ink-faint);">
          <th style="padding: 0.85rem 1rem; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;">Folio</th>
          <th style="padding: 0.85rem 1rem; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;">Cliente / Documento</th>
          <th style="padding: 0.85rem 1rem; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;">Estado</th>
          <th style="padding: 0.85rem 1rem; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;">Riesgo</th>
          <th style="padding: 0.85rem 1rem; text-align: right; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;">Acciones</th>
        </tr>
      </thead>
      <tbody id="resultados-body">
        <tr>
          <td colspan="5" style="padding: 2.5rem; text-align: center; color: var(--ink-faint); font-style: italic;">Cargando formularios...</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  // Cargar formularios al inicio
  document.addEventListener('DOMContentLoaded', () => {
    cargarFormularios();
  });

  // Escuchar envío del buscador
  const searchForm = document.getElementById('search-form');
  searchForm.addEventListener('submit', (e) => {
    e.preventDefault();
    cargarFormularios();
  });

  async function cargarFormularios() {
    const folio = document.getElementById('search-folio').value.trim();
    const nombre = document.getElementById('search-nombre').value.trim();
    
    let queryParams = [];
    if (folio) queryParams.push(`folio=${encodeURIComponent(folio)}`);
    if (nombre) queryParams.push(`nombre=${encodeURIComponent(nombre)}`);
    
    const queryString = queryParams.length ? `?${queryParams.join('&')}` : '';

    try {
      const response = await apiFetch(`/api/formularios${queryString}`);
      const listado = await response.json();
      
      const tbody = document.getElementById('resultados-body');
      tbody.innerHTML = '';

      if (!listado || listado.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" style="padding: 3rem; text-align: center; color: var(--text-secondary);">
              No se encontraron formularios.
            </td>
          </tr>
        `;
        return;
      }

      listado.forEach(f => {
        const tr = document.createElement('tr');
        tr.style.borderBottom = '1px solid var(--rule)';
        tr.style.transition = 'background-color 0.15s ease';
        tr.addEventListener('mouseenter', () => tr.style.backgroundColor = 'var(--surface-alt)');
        tr.addEventListener('mouseleave', () => tr.style.backgroundColor = 'transparent');

        const isGuardado = f.estado === 'GUARDADO';
        const estadoBadge = isGuardado
          ? `<span style="background: var(--success-soft); color: var(--success); border: 1px solid var(--success); padding: 0.25rem 0.55rem; border-radius: 2px; font-size: 0.68rem; font-weight: 600; font-family: var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase;">Guardado</span>`
          : `<span style="background: var(--accent-soft); color: var(--accent); border: 1px solid var(--accent); padding: 0.25rem 0.55rem; border-radius: 2px; font-size: 0.68rem; font-weight: 600; font-family: var(--font-mono); letter-spacing: 0.08em; text-transform: uppercase;">Borrador</span>`;

        let riesgoBadge = '<span style="color: var(--ink-faint); font-family: var(--font-mono); font-size: 0.78rem;">&mdash;</span>';
        if (f.clasificacionRiesgo) {
          const isBajo = f.clasificacionRiesgo === 'BAJO';
          riesgoBadge = isBajo
            ? `<span style="color: var(--success); font-weight: 600; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase;">Bajo</span>`
            : `<span style="color: var(--error); font-weight: 600; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase;">No elegible</span>`;
        }

        const clienteInfo = f.cliente
          ? `<div style="font-weight: 600; color: var(--ink);">${f.cliente.nombre}</div>
             <div style="font-size: 0.76rem; color: var(--ink-faint); font-family: var(--font-mono); margin-top: 0.15rem;">${f.cliente.tipoDocumento} · ${f.cliente.numDocumento}</div>`
          : `<span style="color: var(--ink-faint); font-style: italic;">Sin registrar</span>`;

        let accionesHtml = '';
        if (f.estado === 'BORRADOR') {
          accionesHtml = `<a href="/formularios/${f.id}/identificacion" class="btn btn-secondary" style="padding: 0.35rem 0.85rem; font-size: 0.82rem;">Editar</a>`;
        } else {
          accionesHtml = `
            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
              <a href="/formularios/${f.id}/resumen" class="btn btn-secondary" style="padding: 0.35rem 0.85rem; font-size: 0.82rem;">Resumen</a>
              <button onclick="descargarPDF('${f.id}')" class="btn btn-primary" style="padding: 0.35rem 0.85rem; font-size: 0.82rem;">Descargar</button>
            </div>
          `;
        }

        tr.innerHTML = `
          <td style="padding: 1rem; font-family: var(--font-mono); font-weight: 500; font-size: 0.82rem; color: var(--ink); letter-spacing: 0.04em;">${f.folio || 'BORRADOR'}</td>
          <td style="padding: 1rem;">${clienteInfo}</td>
          <td style="padding: 1rem;">${estadoBadge}</td>
          <td style="padding: 1rem;">${riesgoBadge}</td>
          <td style="padding: 1rem; text-align: right;">${accionesHtml}</td>
        `;

        tbody.appendChild(tr);
      });
    } catch (err) {
      showAlert('Error al cargar la bandeja de formularios', 'error');
    }
  }

  // Crear nuevo Formulario Borrador
  const btnNuevo = document.getElementById('btn-nuevo');
  btnNuevo.addEventListener('click', async () => {
    try {
      const response = await apiFetch('/api/formularios', {
        method: 'POST'
      });
      const data = await response.json();
      if (response.status === 201) {
        window.location.href = `/formularios/${data.id}/identificacion`;
      } else {
        showAlert('No se pudo crear el formulario borrador', 'error');
      }
    } catch (err) {
      showAlert('Error de conexión al crear formulario', 'error');
    }
  });

  // Helper para descargar PDF directamente de forma asíncrona
  async function descargarPDF(id) {
    showAlert('Iniciando generación de PDF...', 'warning');
    try {
      const response = await apiFetch(`/api/formularios/${id}/pdf`);
      const { jobId } = await response.json();

      // Iniciar polling
      const pollInterval = setInterval(async () => {
        const pollRes = await apiFetch(`/api/formularios/${id}/pdf/${jobId}`);
        if (pollRes.status === 200) {
          clearInterval(pollInterval);
          const blob = await pollRes.blob();
          const downloadUrl = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = downloadUrl;
          a.download = `Formulario-${id}.pdf`;
          document.body.appendChild(a);
          a.click();
          a.remove();
          showAlert('PDF descargado con éxito', 'success');
        } else if (pollRes.status === 500) {
          clearInterval(pollInterval);
          showAlert('Error en la generación del PDF', 'error');
        }
      }, 500);
    } catch (err) {
      showAlert('Error al procesar la solicitud del PDF', 'error');
    }
  }
</script>

<%- include('layout_footer') %>
