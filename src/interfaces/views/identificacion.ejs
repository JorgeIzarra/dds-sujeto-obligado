<%- include('layout_header') %>

<div class="glass-card" style="max-width: 800px; margin: 2rem auto;">
  <!-- Progress Wizard -->
  <div class="wizard-steps">
    <a href="/formularios/<%= id %>/identificacion" class="wizard-step active">
      <span class="step-number">1</span> Identificación
    </a>
    <a href="/formularios/<%= id %>/contacto" class="wizard-step">
      <span class="step-number">2</span> Contacto
    </a>
    <a href="/formularios/<%= id %>/perfil" class="wizard-step">
      <span class="step-number">3</span> Perfil
    </a>
    <a href="/formularios/<%= id %>/documentos" class="wizard-step">
      <span class="step-number">4</span> Documentos
    </a>
    <a href="/formularios/<%= id %>/resumen" class="wizard-step">
      <span class="step-number">5</span> Resumen
    </a>
  </div>

  <h2>Paso 1: Identificación del Cliente</h2>
  <p>Ingrese los datos identificativos del cliente para iniciar el proceso de debida diligencia.</p>

  <form id="identificacion-form">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
      <div class="form-group">
        <label for="nombre">Nombre Completo / Razón Social</label>
        <input type="text" id="nombre" class="input-control" required placeholder="Ej: Juan Perez">
      </div>

      <div class="form-group">
        <label for="tipoCliente">Tipo de Cliente</label>
        <select id="tipoCliente" class="input-control" required style="background-color: rgb(15 23 42);">
          <option value="NATURAL">Persona Natural</option>
          <option value="JURIDICA">Persona Jurídica</option>
        </select>
      </div>

      <div class="form-group">
        <label for="tipoDocumento">Tipo de Documento</label>
        <select id="tipoDocumento" class="input-control" required style="background-color: rgb(15 23 42);">
          <option value="CEDULA">Cédula de Identidad</option>
          <option value="PASAPORTE">Pasaporte</option>
          <option value="RUC">RUC (Registro Único de Contribuyente)</option>
        </select>
      </div>

      <div class="form-group">
        <label for="numDocumento">Número de Documento</label>
        <input type="text" id="numDocumento" class="input-control" required placeholder="Ej: 8-999-9999 o PE-123456">
        <span id="doc-help" style="font-size: 0.8rem; color: var(--text-secondary); display: block; margin-top: 0.25rem;">
          Para cédulas panameñas, use el formato: provincia-tomo-asiento (Ej: 8-999-9999).
        </span>
      </div>

      <div class="form-group">
        <label for="fechaNacimiento">Fecha de Nacimiento / Constitución</label>
        <input type="date" id="fechaNacimiento" class="input-control">
      </div>

      <div class="form-group">
        <label for="nacionalidad">Nacionalidad / País de Registro</label>
        <input type="text" id="nacionalidad" class="input-control" required placeholder="Ej: Panameña">
      </div>
    </div>

    <div class="form-group checkbox-group" style="background: rgba(255, 255, 255, 0.02); padding: 1rem; border-radius: 8px; border: 1px solid var(--glass-border);">
      <input type="checkbox" id="esPEP" class="checkbox-control">
      <div>
        <label for="esPEP" style="margin: 0; cursor: pointer; color: var(--text-primary);">El cliente es una Persona Expuesta Políticamente (PEP)</label>
        <p style="margin: 0.25rem 0 0 0; font-size: 0.75rem; color: var(--text-secondary);">
          De acuerdo a la Ley 23, los PEPs requieren debida diligencia reforzada y no son elegibles para trámites DDS.
        </p>
      </div>
    </div>

    <div style="display: flex; justify-content: space-between; margin-top: 2.5rem; border-top: 1px solid var(--glass-border); padding-top: 1.5rem;">
      <a href="/formularios" class="btn btn-secondary">Cancelar</a>
      <button type="submit" class="btn btn-primary">Siguiente Paso ➡️</button>
    </div>
  </form>
</div>

<script>
  const formId = '<%= id %>';

  // Cargar datos preexistentes
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const response = await apiFetch(`/api/formularios/${formId}`);
      if (response.status === 200) {
        const data = await response.json();
        if (data.cliente) {
          document.getElementById('nombre').value = data.cliente.nombre || '';
          document.getElementById('tipoCliente').value = data.cliente.tipoCliente || 'NATURAL';
          document.getElementById('tipoDocumento').value = data.cliente.tipoDocumento || 'CEDULA';
          document.getElementById('numDocumento').value = data.cliente.numDocumento || '';
          document.getElementById('fechaNacimiento').value = data.cliente.fechaNacimiento || '';
          document.getElementById('nacionalidad').value = data.cliente.nacionalidad || '';
          document.getElementById('esPEP').checked = !!data.cliente.esPep;
        }
      }
    } catch (err) {
      console.error('Error al cargar datos del formulario:', err);
    }
  });

  // Validaciones y ayuda dinámica según tipo de documento
  const tipoDocSelect = document.getElementById('tipoDocumento');
  const docHelp = document.getElementById('doc-help');
  const numDocInput = document.getElementById('numDocumento');

  tipoDocSelect.addEventListener('change', () => {
    if (tipoDocSelect.value === 'CEDULA') {
      docHelp.textContent = 'Formato de cédula panameña obligatorio: provincia-tomo-asiento (Ej: 8-999-9999 o PE-1234-5678).';
      numDocInput.placeholder = 'Ej: 8-999-9999';
    } else {
      docHelp.textContent = 'Permite letras, números y guiones. Sin espacios ni caracteres especiales.';
      numDocInput.placeholder = 'Ej: PE-123456';
    }
  });

  // Envío del formulario
  const form = document.getElementById('identificacion-form');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const payload = {
      nombre: document.getElementById('nombre').value.trim(),
      tipoCliente: document.getElementById('tipoCliente').value,
      tipoDocumento: document.getElementById('tipoDocumento').value,
      numDocumento: document.getElementById('numDocumento').value.trim(),
      fechaNacimiento: document.getElementById('fechaNacimiento').value || undefined,
      nacionalidad: document.getElementById('nacionalidad').value.trim(),
      esPEP: document.getElementById('esPEP').checked
    };

    try {
      const response = await apiFetch(`/api/formularios/${formId}/identificacion`, {
        method: 'PUT',
        body: JSON.stringify(payload)
      });

      const data = await response.json();

      if (response.status === 200) {
        window.location.href = `/formularios/${formId}/contacto`;
      } else {
        // Manejar errores de validación de Zod o regex
        if (data.error && data.error.campos) {
          const fieldErrors = data.error.campos;
          const msg = Object.keys(fieldErrors)
            .map(k => `${k}: ${fieldErrors[k].join(', ')}`)
            .join(' | ');
          showAlert(data.error.mensaje + ' (' + msg + ')', 'error');
        } else {
          showAlert(data.error?.mensaje || 'Error al guardar los datos', 'error');
        }
      }
    } catch (err) {
      showAlert('Error de conexión con el servidor', 'error');
    }
  });
</script>

<%- include('layout_footer') %>
