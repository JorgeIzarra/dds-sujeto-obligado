# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — DDS Sujeto Obligado
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA versiones el .env real (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL="postgresql://dds:dds_dev_password@localhost:5432/dds_db"

# ── PostgreSQL (docker-compose) ───────────────────────────────────────────────
POSTGRES_USER=dds
POSTGRES_PASSWORD=dds_dev_password
POSTGRES_DB=dds_db

# ── Cifrado en reposo (se añade en Sesión 2 — SPEC-SEC-01) ───────────────────
# ENCRYPTION_KEY=<clave AES-256 de 32 bytes en base64; generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))">
