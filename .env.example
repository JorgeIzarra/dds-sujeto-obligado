# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — DDS Sujeto Obligado
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA versiones el .env real (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL="postgresql://dds:dds_dev_password@localhost:5432/dds_db"

# ── PostgreSQL (docker-compose) ───────────────────────────────────────────────
POSTGRES_USER=dds
POSTGRES_PASSWORD=dds_dev_password
POSTGRES_DB=dds_db

# ── Cifrado en reposo (SPEC-SEC-01) ──────────────────────────────────────────
# Clave AES-256 de 32 bytes (64 caracteres hex). Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=cambiar_por_clave_de_64_caracteres_hexadecimales
