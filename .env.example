# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — DDS Sujeto Obligado
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA versiones el .env real (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL="postgresql://dds:dds_dev_password@localhost:5433/dds_db"

# ── PostgreSQL (docker-compose) ───────────────────────────────────────────────
POSTGRES_USER=dds
POSTGRES_PASSWORD=dds_dev_password
POSTGRES_DB=dds_db

# ── Cifrado en reposo (SPEC-SEC-01 — implementado en Sesión 2) ───────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Obligatoria para arrancar la aplicación; 32 bytes exactos en base64 (44 chars).
ENCRYPTION_KEY=<reemplazar_con_clave_generada>
